{
  "name": "doctero",
  "version": "0.0.1",
  "author": {
    "name": "Yuri Martins",
    "email": "develop@yumartins.com.br"
  },
  "private": true,
  "scripts": {
    "commit": "cz",
    "web:dev": "yarn workspace @apps/web run dev",
    "admin:dev": "yarn workspace @apps/admin run dev",
    "web:build": "yarn workspace @apps/web run build",
    "web:start": "yarn workspace @apps/web run start",
    "core:watch": "bash .bin/run.sh core watch $*",
    "core:build": "bash .bin/run.sh core build $*",
    "admin:build": "yarn workspace @apps/admin run build"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "core/*"
    ]
  },
  "dependencies": {
    "@unform/web": "^2.1.6",
    "@uxoctopus/core": "^0.1.3",
    "@uxoctopus/helpers": "^0.1.0",
    "@uxoctopus/hooks": "^0.1.1",
    "@uxoctopus/styles": "^0.1.1",
    "axios": "^0.21.1",
    "framer-motion": "^4.1.17",
    "js-cookie": "^3.0.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-lottie": "^1.2.3",
    "styled-components": "^5.3.0",
    "yup": "^0.32.9"
  },
  "devDependencies": {
    "@babel/cli": "^7.14.8",
    "@commitlint/cli": "^13.1.0",
    "@commitlint/config-conventional": "^13.1.0",
    "@types/js-cookie": "^2.2.7",
    "@types/react": "^17.0.15",
    "@types/react-dom": "^17.0.9",
    "@types/react-lottie": "^1.2.6",
    "@types/styled-components": "^5.1.11",
    "@typescript-eslint/eslint-plugin": "^4.28.5",
    "@typescript-eslint/parser": "^4.28.5",
    "commitizen": "^4.2.4",
    "dotenv": "^10.0.0",
    "dotenv-cli": "^4.0.0",
    "eslint": "^7.31.0",
    "eslint-config-airbnb-typescript": "^12.3.1",
    "eslint-import-resolver-typescript": "^2.4.0",
    "eslint-plugin-import": "^2.23.4",
    "eslint-plugin-import-helpers": "^1.1.0",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-react": "^7.24.0",
    "eslint-plugin-react-hooks": "^4.2.0",
    "husky": "^7.0.1",
    "lerna": "^4.0.0",
    "postcss": "^8.3.6",
    "typescript": "^4.3.5"
  }
}
