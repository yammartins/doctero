{
  "name": "doctero",
  "version": "0.0.1",
  "author": {
    "name": "Yuri Martins",
    "email": "develop@yumartins.com.br"
  },
  "private": true,
  "scripts": {
    "web": "yarn workspace @apps/web run develop",
    "core": "bash .bin/run.sh core watch $*",
    "build": "bash .bin/run.sh core build $*",
    "admin": "yarn workspace @apps/admin run develop",
    "commit": "cz",
    "build:web": "yarn workspace @apps/web run build",
    "build:admin": "yarn workspace @apps/admin run build"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "core/*"
    ]
  },
  "dependencies": {
    "@uxoctopus/core": "^0.0.17",
    "@uxoctopus/styles": "^0.0.11",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "styled-components": "^5.2.3"
  },
  "devDependencies": {
    "@babel/cli": "^7.13.14",
    "@commitlint/cli": "^12.1.1",
    "@commitlint/config-conventional": "^12.1.1",
    "@types/react": "^17.0.3",
    "@types/react-dom": "^17.0.3",
    "@types/styled-components": "^5.1.9",
    "@typescript-eslint/eslint-plugin": "^4.22.0",
    "@typescript-eslint/parser": "^4.22.0",
    "commitizen": "^4.2.3",
    "eslint": "^7.24.0",
    "eslint-config-airbnb-typescript": "^12.3.1",
    "eslint-import-resolver-typescript": "^2.4.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-import-helpers": "^1.1.0",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-react": "^7.23.2",
    "eslint-plugin-react-hooks": "^4.2.0",
    "husky": "^6.0.0",
    "lerna": "^4.0.0",
    "postcss": "^8.2.10",
    "typescript": "^4.2.4"
  }
}
