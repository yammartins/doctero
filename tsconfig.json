{
  "include": [
    "apps/**/*",
    "core/**/*"
  ],
  "exclude": [
    "dist",
    "build",
    "node_modules"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": [
      "es6",
      "dom",
      "es2016",
      "es2017",
      "esnext"
    ],
    "paths": {
      "@apps/*": [
        "apps/*"
      ],
      "@core/*": [
        "core/*/dist"
      ]
    },
    "noEmit": true,
    "module": "esnext",
    "target": "es5",
    "baseUrl": ".",
    "allowJs": false,
    "sourceMap": true,
    "declaration": true,
    "noImplicitAny": false,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "strictNullChecks": true,
    "moduleResolution": "node",
    "noImplicitReturns": true,
    "noUnusedParameters": true,
    "allowSyntheticDefaultImports": true,
    "suppressImplicitAnyIndexErrors": true,
    "forceConsistentCasingInFileNames": true,
  }
}
